---

<div class="ecosystem">
  <div class="orbit"></div>
  <div class="orbit orbit-two"></div>

  <div class="core">
    <span class="core-icon">
      <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="5" stroke="currentColor" stroke-width="1.8"/>
        <circle cx="16" cy="5"  r="2.2" fill="currentColor"/>
        <circle cx="16" cy="27" r="2.2" fill="currentColor"/>
        <circle cx="5"  cy="16" r="2.2" fill="currentColor"/>
        <circle cx="27" cy="16" r="2.2" fill="currentColor"/>
        <line x1="16" y1="7.2"  x2="16" y2="11" stroke="currentColor" stroke-width="1.5"/>
        <line x1="16" y1="21"   x2="16" y2="24.8" stroke="currentColor" stroke-width="1.5"/>
        <line x1="7.2" y1="16"  x2="11" y2="16"   stroke="currentColor" stroke-width="1.5"/>
        <line x1="21"  y1="16"  x2="24.8" y2="16" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </span>
    <span class="core-label">Growth<br>Ecosystem</span>
  </div>

  <div class="node node-ai">
    <span class="node-icon">
      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <rect x="3" y="6" width="14" height="10" rx="2.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M7 6V4.5a3 3 0 0 1 6 0V6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        <circle cx="7.5" cy="11" r="1" fill="currentColor"/>
        <circle cx="12.5" cy="11" r="1" fill="currentColor"/>
        <path d="M8.5 13.5 a1.5 1.5 0 0 0 3 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    </span>
    <span>AI &amp; ML</span>
  </div>

  <div class="node node-software">
    <span class="node-icon">
      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M6.5 7 L3.5 10 L6.5 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M13.5 7 L16.5 10 L13.5 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M11.5 5 L8.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </span>
    <span>Software Dev</span>
  </div>

  <div class="node node-marketing">
    <span class="node-icon">
      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M4 13 V8 L15 4 V16 L4 13 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        <path d="M4 13 L4 16 a1.5 1.5 0 0 0 3 0 V13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M15 9 Q18 10 15 11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    </span>
    <span>Marketing</span>
  </div>

  <div class="node node-automation">
    <span class="node-icon">
      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M10 3 V5 M10 15 V17 M3 10 H5 M15 10 H17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        <path d="M5.05 5.05 L6.46 6.46 M13.54 13.54 L14.95 14.95 M14.95 5.05 L13.54 6.46 M6.46 13.54 L5.05 14.95" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    </span>
    <span>Automation</span>
  </div>

  <div class="node node-analytics">
    <span class="node-icon">
      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 15 L7 9 L11 12 L16 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="16" cy="5" r="1.5" fill="currentColor"/>
      </svg>
    </span>
    <span>Analytics</span>
  </div>

  <div class="node node-creative">
    <span class="node-icon">
      <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M4 16 L7.5 12.5 M7.5 12.5 L13 5 a2.5 2.5 0 0 1 3.5 3.5 L10 14.5 Z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M4 16 L4.5 13.5 L7.5 12.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <span>Creative</span>
  </div>
</div>

<style>
  .ecosystem {
    position: relative;
    width: 100%; max-width: 560px;
    aspect-ratio: 1 / 1;
    margin-inline: auto;
  }
  .ecosystem::before {
    position: absolute; inset: 12%; border-radius: 50%;
    background: radial-gradient(circle, rgba(59,130,246,.22), rgba(6,182,212,.06) 52%, transparent 70%);
    content: "";
  }

  /* Orbit rings */
  .orbit {
    position: absolute; inset: 15%;
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 50%;
  }
  .orbit-two {
    inset: 29%;
    border-style: dashed;
    border-color: rgba(233,113,66,.45);
    transform: rotate(24deg);
  }

  /* Central core */
  .core {
    position: absolute; z-index: 2;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    display: flex; flex-direction: column; align-items: center; gap: 7px;
    width: 108px; height: 108px; justify-content: center;
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 50%;
    background: linear-gradient(145deg, rgba(10,93,240,.85), rgba(6,182,212,.7));
    box-shadow: 0 0 0 8px rgba(10,93,240,.12), 0 16px 40px rgba(0,0,0,.3);
    color: #fff;
  }
  .core-icon { display: flex; align-items: center; }
  .core-icon svg { width: 28px; height: 28px; }
  .core-label { font-size: .62rem; font-weight: 700; text-align: center; line-height: 1.3; letter-spacing: .02em; opacity: .92; }

  /* Orbit nodes */
  .node {
    position: absolute; z-index: 2;
    min-width: 104px;
    display: flex; align-items: center; gap: 8px;
    padding: 11px 14px;
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 12px;
    color: #1e2d45;
    background: rgba(255,255,255,.96);
    box-shadow: 0 12px 36px rgba(0,0,0,.25);
    backdrop-filter: blur(12px);
    font-size: .77rem; font-weight: 700;
    white-space: nowrap;
  }
  .node-icon {
    width: 28px; height: 28px; flex-shrink: 0;
    display: grid; place-items: center;
    border-radius: 7px;
    background: #eef3fb;
    color: #0a5df0;
  }
  .node-icon svg { width: 16px; height: 16px; }

  /* Node positions */
  .node-ai         { top: 8%;  left: 50%; transform: translateX(-50%); }
  .node-software   { top: 22%; right: 4%; }
  .node-marketing  { bottom: 22%; right: 4%; }
  .node-automation { bottom: 8%; left: 50%; transform: translateX(-50%); }
  .node-analytics  { bottom: 22%; left: 4%; }
  .node-creative   { top: 22%; left: 4%; }

  @media (max-width: 640px) {
    .node { font-size: .68rem; min-width: 86px; padding: 8px 10px; gap: 6px; }
    .node-icon { width: 22px; height: 22px; }
    .node-icon svg { width: 13px; height: 13px; }
    .core { width: 84px; height: 84px; }
    .core-icon svg { width: 22px; height: 22px; }
    .core-label { font-size: .55rem; }
  }
</style>
