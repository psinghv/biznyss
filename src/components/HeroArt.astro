---
interface Props {
  label?: string;
}

const { label = 'AI-Powered Growth' } = Astro.props;
---
<div class="hero-art" aria-label={`${label} visual system`}>
  <div class="art-grid"></div>
  <div class="art-orbit orbit-one"></div>
  <div class="art-orbit orbit-two"></div>
  <div class="art-core">
    <span class="core-mark">B</span>
    <strong>{label}</strong>
    <small>Strategy connected to execution</small>
  </div>
  <div class="art-card card-one"><i></i><span>Intelligence</span><b>AI</b></div>
  <div class="art-card card-two"><i></i><span>Execution</span><b>Build</b></div>
  <div class="art-card card-three"><i></i><span>Performance</span><b>Growth</b></div>
  <div class="art-signal signal-one"></div>
  <div class="art-signal signal-two"></div>
</div>

<style>
  .hero-art {
    position: relative;
    width: min(100%, 570px);
    aspect-ratio: 1.08;
    justify-self: end;
    overflow: hidden;
    border: 1px solid rgba(18,79,109,.12);
    border-radius: 28px;
    background:
      radial-gradient(circle at 72% 24%, rgba(10,93,240,.14), transparent 28%),
      radial-gradient(circle at 25% 82%, rgba(233,113,66,.12), transparent 25%),
      linear-gradient(145deg, rgba(255,255,255,.92), rgba(238,243,247,.82));
    box-shadow: 0 28px 80px rgba(13,23,32,.08);
  }
  .art-grid {
    position: absolute;
    inset: 0;
    opacity: .42;
    background-image:
      linear-gradient(rgba(18,79,109,.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(18,79,109,.08) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: linear-gradient(to bottom right, black, transparent 82%);
  }
  .art-orbit { position: absolute; border: 1px solid rgba(10,93,240,.17); border-radius: 50%; animation: orbit 16s linear infinite; }
  .orbit-one { width: 72%; aspect-ratio: 1; left: 14%; top: 13%; }
  .orbit-two { width: 48%; aspect-ratio: 1; left: 26%; top: 25%; border-style: dashed; border-color: rgba(233,113,66,.25); animation-direction: reverse; animation-duration: 12s; }
  .art-core {
    position: absolute;
    z-index: 2;
    width: 45%;
    min-height: 42%;
    left: 27.5%;
    top: 29%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    border: 1px solid rgba(255,255,255,.55);
    border-radius: 25px;
    color: white;
    background: linear-gradient(145deg, #124f6d, #0a5df0);
    box-shadow: 0 24px 55px rgba(10,93,240,.24);
    text-align: center;
  }
  .core-mark { width: 37px; height: 37px; display: grid; place-items: center; margin-bottom: 13px; border: 1px solid rgba(255,255,255,.35); border-radius: 11px; font-weight: 900; }
  .art-core strong { max-width: 180px; font-size: clamp(.82rem, 1.3vw, 1.05rem); line-height: 1.25; }
  .art-core small { margin-top: 8px; color: #c6d9e8; font-size: .62rem; }
  .art-card {
    position: absolute;
    z-index: 3;
    min-width: 122px;
    display: grid;
    grid-template-columns: 8px 1fr;
    gap: 2px 9px;
    padding: 12px 14px;
    border: 1px solid rgba(220,229,239,.95);
    border-radius: 12px;
    background: rgba(255,255,255,.92);
    box-shadow: 0 14px 35px rgba(13,23,32,.11);
    backdrop-filter: blur(10px);
    animation: float 5s ease-in-out infinite;
  }
  .art-card i { grid-row: 1 / 3; align-self: center; width: 7px; height: 7px; border-radius: 50%; background: var(--orange); box-shadow: 0 0 0 5px rgba(233,113,66,.12); }
  .art-card span { color: var(--muted); font-size: .56rem; text-transform: uppercase; }
  .art-card b { color: var(--navy); font-size: .78rem; }
  .card-one { left: 5%; top: 17%; }
  .card-two { right: 4%; top: 48%; animation-delay: -1.6s; }
  .card-three { left: 9%; bottom: 9%; animation-delay: -3s; }
  .art-signal { position: absolute; width: 9px; height: 9px; border-radius: 50%; background: var(--blue); box-shadow: 0 0 0 8px rgba(10,93,240,.1); animation: pulse 2.2s ease-out infinite; }
  .signal-one { right: 18%; top: 18%; }
  .signal-two { right: 25%; bottom: 16%; animation-delay: -1.1s; }
  @keyframes orbit { to { transform: rotate(360deg); } }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(10,93,240,.25); } 70%,100% { box-shadow: 0 0 0 15px rgba(10,93,240,0); } }
  @media (max-width: 960px) { .hero-art { width: min(100%, 520px); justify-self: center; } }
  @media (max-width: 520px) {
    .hero-art { border-radius: 20px; }
    .art-card { min-width: 105px; padding: 9px 11px; }
    .art-core { width: 48%; left: 26%; padding: 16px; }
  }
</style>
