---
import {
  CalendarDays,
  Mail,
  MessageCircle,
  Phone,
} from 'lucide-react';
import { capabilities, solutions } from '../data/site';
---
<footer class="footer">
  <!-- World map banner -->
  <div class="footer-map-wrap" aria-hidden="true">
    <img
      src="/images/WhatsApp_Image_2026-07-20_at_4.14.21_PM.jpeg"
      alt="World map — global client experience"
      class="footer-map-img"
      loading="lazy"
      decoding="async"
    />
    <div class="footer-map-overlay"></div>
    <span class="footer-map-label">Global client experience</span>
  </div>

  <!-- Main link columns -->
  <div class="container footer-main">
    <!-- Brand -->
    <div class="brand-col">
      <a class="footer-logo" href="/">Biznyss</a>
      <span class="footer-tagline">AI-Powered Growth Ecosystem</span>
      <p>Helping businesses build, market, automate, and scale through AI, technology, creative production, and growth systems.</p>
      <div class="socials" aria-label="Social links">
        <a href="#" aria-label="LinkedIn"><span>in</span></a>
        <a href="#" aria-label="YouTube"><span>YT</span></a>
        <a href="#" aria-label="Instagram"><span>IG</span></a>
      </div>
    </div>

    <!-- Capabilities -->
    <div class="footer-col">
      <h3>Capabilities</h3>
      {capabilities.map((item) => (
        <a href={`/capabilities/${item.slug}`}>{item.name}</a>
      ))}
      <a href="/capabilities" class="footer-col-all">All Capabilities &rarr;</a>
    </div>

    <!-- Solutions -->
    <div class="footer-col">
      <h3>Solutions</h3>
      {solutions.map((item) => (
        <a href={`/solutions/${item.slug}`}>{item.name}</a>
      ))}
      <a href="/solutions" class="footer-col-all">All Solutions &rarr;</a>
    </div>

    <!-- Work -->
    <div class="footer-col">
      <h3>Work &amp; Insights</h3>
      <a href="/case-studies">Case Studies</a>
      <a href="/case-studies/ecommerce-growth-campaign">E-Commerce Growth</a>
      <a href="/case-studies/ai-video-campaign-real-estate-developer">AI Video Campaign</a>
      <a href="/case-studies/b2b-lead-generation-campaign">B2B Lead Generation</a>
      <a href="/case-studies/enterprise-logistics-management-platform">Logistics Platform</a>
      <a href="/case-studies/saas-platform-assessment-company">SaaS Assessment</a>
      <a href="/insights">Insights</a>
    </div>

    <!-- Company -->
    <div class="footer-col">
      <h3>Company</h3>
      <a href="/about">About Us</a>
      <a href="/about#approach">Our Approach</a>
      <a href="/about#team">Team</a>
      <a href="/capabilities">What We Do</a>
      <a href="/solutions">How We Engage</a>
      <a href="/contact">Careers</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms &amp; Conditions</a>
    </div>

    <!-- Contact -->
    <div class="footer-col contact-col">
      <h3>Contact</h3>
      <a href="mailto:hello@biznyss.com"><Mail size={14} />hello@biznyss.com</a>
      <a href="tel:+919876543210"><Phone size={14} />+91 98765 43210</a>
      <a href="https://wa.me/919876543210"><MessageCircle size={14} />Chat on WhatsApp</a>
      <a href="/contact"><CalendarDays size={14} />Book Strategy Call</a>
      <div class="footer-cta-strip">
        <a href="/contact" class="footer-cta-btn">Start a project</a>
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {new Date().getFullYear()} Biznyss.com. All rights reserved.</span>
    <div class="footer-bottom-links">
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms &amp; Conditions</a>
      <a href="/sitemap-index.xml">Sitemap</a>
    </div>
  </div>
</footer>

<style>
  /* ── Wrapper ─────────────────────────────────────────────── */
  .footer {
    position: relative;
    overflow: hidden;
    padding: 0 0 24px;
    border-top: 1px solid var(--border);
    color: #405063;
    background: linear-gradient(180deg, #f9fbfd 0%, #f1f5f8 100%);
  }

  /* ── World map ───────────────────────────────────────────── */
  .footer-map-wrap {
    position: relative;
    width: 100%;
    max-height: 260px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .footer-map-img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: .82;
    filter: saturate(.55) brightness(1.08);
  }
  .footer-map-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(249,251,253,0) 0%, rgba(249,251,253,.92) 100%),
      linear-gradient(to right, rgba(249,251,253,.45) 0%, transparent 20%, transparent 80%, rgba(249,251,253,.45) 100%);
    pointer-events: none;
  }
  .footer-map-label {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    color: #52687b;
    font-size: .68rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 5px 14px;
    background: rgba(255,255,255,.72);
    border: 1px solid #d5dfe8;
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }

  /* ── Main grid ───────────────────────────────────────────── */
  .footer-main {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.35fr 0.9fr 0.9fr 1.1fr 0.85fr 1fr;
    align-items: start;
    gap: 20px 28px;
    padding-top: 52px;
  }

  /* ── Brand ───────────────────────────────────────────────── */
  .brand-col { padding-right: 12px; }
  .footer-logo {
    display: inline-block;
    color: #09152e;
    font-size: 1.65rem;
    font-weight: 850;
    letter-spacing: -.055em;
    line-height: 1;
  }
  .footer-logo::first-letter { color: var(--orange); }
  .footer-tagline {
    display: block;
    margin-top: 7px;
    color: var(--navy);
    font-size: .6rem;
    font-weight: 800;
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .brand-col p {
    max-width: 290px;
    margin-top: 18px;
    color: #526476;
    font-size: .9rem;
    line-height: 1.62;
  }
  .socials { display: flex; gap: 8px; margin-top: 22px; }
  .socials a {
    width: 31px;
    height: 31px;
    display: grid;
    place-items: center;
    border: 1px solid #d4dee7;
    border-radius: 8px;
    color: var(--navy);
    background: white;
    transition: color .2s, border-color .2s, transform .2s;
  }
  .socials span { font-size: .7rem; font-weight: 850; line-height: 1; }
  .socials a:hover { transform: translateY(-2px); border-color: var(--blue); color: var(--blue); }

  /* ── Link columns ────────────────────────────────────────── */
  .footer-col {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding-top: 2px;
  }
  .footer h3 {
    margin: 0 0 16px;
    color: #122038;
    font-size: .78rem;
    font-weight: 850;
    line-height: 1.25;
    letter-spacing: .07em;
    text-transform: uppercase;
  }
  .footer-col > a {
    display: block;
    margin: 0 0 9px;
    color: #495c6f;
    font-size: .88rem;
    line-height: 1.4;
    transition: color .2s;
  }
  .footer-col > a:hover { color: var(--blue); }
  .footer-col-all {
    margin-top: 6px;
    color: var(--blue) !important;
    font-weight: 700;
    font-size: .82rem !important;
  }

  /* ── Contact column ──────────────────────────────────────── */
  .contact-col > a {
    display: grid;
    grid-template-columns: 17px minmax(0, 1fr);
    align-items: center;
    gap: 8px;
    white-space: normal;
  }
  .contact-col svg { flex: 0 0 auto; color: var(--navy); }
  .footer-cta-strip { margin-top: 18px; }
  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border-radius: 999px;
    background: var(--orange);
    color: #fff;
    font-size: .82rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 6px 18px rgba(233,113,66,.28);
    transition: transform .2s, box-shadow .2s;
  }
  .footer-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(233,113,66,.38); }

  /* ── Bottom bar ──────────────────────────────────────────── */
  .footer-bottom {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 46px;
    padding-top: 20px;
    border-top: 1px solid #d5dfe8;
    color: #687a8a;
    font-size: .72rem;
  }
  .footer-bottom-links { display: flex; gap: 28px; }
  .footer-bottom a:hover { color: var(--blue); }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .footer-main {
      grid-template-columns: 1.35fr repeat(2, 1fr) 1.1fr repeat(2, 1fr);
    }
  }
  @media (max-width: 960px) {
    .footer-main {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px 24px;
    }
    .brand-col { grid-column: 1 / -1; }
    .brand-col p { max-width: 480px; }
    .footer-map-img { height: 200px; }
  }
  @media (max-width: 640px) {
    .footer-main {
      grid-template-columns: repeat(2, 1fr);
      gap: 28px 20px;
    }
    .brand-col { grid-column: 1 / -1; }
    .contact-col { grid-column: 1 / -1; }
    .footer-map-img { height: 160px; }
    .footer-map-label { font-size: .6rem; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .footer-bottom-links { flex-wrap: wrap; gap: 12px 20px; }
  }
  @media (max-width: 380px) {
    .footer-main { grid-template-columns: 1fr; }
    .brand-col, .contact-col { grid-column: auto; }
  }
</style>
