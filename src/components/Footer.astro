---
import {
  CalendarDays,
  Mail,
  MessageCircle,
  Phone,
} from 'lucide-react';
import { capabilities, solutions } from '../data/site';
---
<footer class="footer">
  <div class="container footer-main">
    <div class="brand-col">
      <a class="footer-logo" href="/">Biznyss</a>
      <span class="footer-tagline">AI-Powered Growth Ecosystem</span>
      <p>Helping businesses build, market, automate, and scale through AI, technology, creative production, and growth systems.</p>
      <div class="socials" aria-label="Social links">
        <a href="#" aria-label="LinkedIn"><span>in</span></a>
        <a href="#" aria-label="YouTube"><span>YT</span></a>
        <a href="#" aria-label="Instagram"><span>IG</span></a>
      </div>
    </div>

    <div class="footer-col">
      <h3>Capabilities</h3>
      {capabilities.map((item) => <a href={`/capabilities/${item.slug}`}>{item.name}</a>)}
    </div>

    <div class="footer-col">
      <h3>Solutions</h3>
      {solutions.map((item) => <a href={`/solutions/${item.slug}`}>{item.name}</a>)}
    </div>

    <div class="footer-col">
      <h3>Company</h3>
      <a href="/about">About Us</a>
      <a href="/case-studies">Case Studies</a>
      <a href="/insights">Insights</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col contact-col">
      <h3>Contact</h3>
      <a href="mailto:hello@biznyss.com"><Mail size={14} />hello@biznyss.com</a>
      <a href="tel:+919876543210"><Phone size={14} />+91 98765 43210</a>
      <a href="https://wa.me/919876543210"><MessageCircle size={14} />Chat on WhatsApp</a>
      <a href="/contact"><CalendarDays size={14} />Book Strategy Call</a>
    </div>

    <div class="world-map" aria-label="Global client experience">
      <svg class="map-svg" viewBox="0 0 1000 500" role="img" aria-label="World map">
        <defs>
          <pattern id="dotPattern" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
            <circle cx="3" cy="3" r="2.1" fill="#2471c8" opacity=".55" />
          </pattern>
          <pattern id="dotPatternAccent" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
            <circle cx="3" cy="3" r="2.6" fill="#0a5df0" opacity=".9" />
          </pattern>
        </defs>
        <g>
          <path fill="url(#dotPattern)" d="M150 180 C160 165 175 155 195 152 L215 150 L240 155 L255 165 L262 175 L258 188 L248 195 L230 198 L215 205 L200 210 L185 208 L170 200 L155 190 Z" />
          <path fill="url(#dotPattern)" d="M270 160 L285 155 L300 158 L310 168 L305 178 L292 182 L278 178 Z" />
          <path fill="url(#dotPattern)" d="M330 155 L350 150 L375 155 L390 165 L395 180 L388 195 L375 200 L360 198 L345 190 L335 175 Z" />
          <path fill="url(#dotPattern)" d="M410 145 L435 140 L465 145 L490 155 L510 165 L530 160 L555 165 L575 175 L590 185 L595 200 L585 210 L560 213 L535 210 L510 215 L485 210 L460 200 L440 190 L420 180 L410 165 Z" />
          <path fill="url(#dotPattern)" d="M600 155 L625 150 L650 155 L670 165 L680 180 L675 195 L660 205 L640 208 L620 200 L605 185 Z" />
          <path fill="url(#dotPattern)" d="M700 170 L730 165 L770 170 L800 180 L820 195 L825 210 L815 225 L790 230 L760 225 L730 215 L710 200 L695 185 Z" />
          <path fill="url(#dotPattern)" d="M830 210 L855 205 L880 210 L895 220 L900 235 L888 248 L865 250 L845 245 L832 235 Z" />
          <path fill="url(#dotPattern)" d="M340 220 L365 215 L385 225 L395 245 L390 270 L375 295 L355 305 L335 300 L325 280 L330 255 Z" />
          <path fill="url(#dotPattern)" d="M460 225 L485 220 L510 230 L520 250 L515 275 L500 295 L480 305 L460 300 L450 280 L455 255 Z" />
          <path fill="url(#dotPattern)" d="M580 340 L605 335 L630 345 L640 365 L635 390 L620 410 L600 415 L580 410 L570 390 L575 365 Z" />
          <path fill="url(#dotPattern)" d="M780 350 L800 345 L825 350 L845 360 L850 375 L840 390 L820 395 L795 390 L780 375 Z" />
        </g>
        <g class="map-points">
          <circle cx="220" cy="185" r="5" fill="url(#dotPatternAccent)" />
          <circle cx="450" cy="170" r="5" fill="url(#dotPatternAccent)" />
          <circle cx="560" cy="180" r="5" fill="url(#dotPatternAccent)" />
          <circle cx="750" cy="195" r="5" fill="url(#dotPatternAccent)" />
          <circle cx="860" cy="225" r="5" fill="url(#dotPatternAccent)" />
          <circle cx="600" cy="375" r="5" fill="url(#dotPatternAccent)" />
        </g>
      </svg>
      <span>Global client experience</span>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {new Date().getFullYear()} Biznyss.com. All rights reserved.</span>
    <div>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms & Conditions</a>
      <a href="/sitemap-index.xml">Sitemap</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    padding: 72px 0 24px;
    border-top: 1px solid var(--border);
    color: #405063;
    background:
      radial-gradient(circle at 88% 15%, rgba(10,93,240,.07), transparent 26%),
      linear-gradient(180deg, #f9fbfd 0%, #f1f5f8 100%);
  }
  .footer::before { position: absolute; width: 440px; height: 440px; left: -280px; bottom: -310px; border: 1px solid rgba(18,79,109,.08); border-radius: 50%; content: ""; }
  .footer-main { position: relative; z-index: 1; display: grid; grid-template-columns: 1.25fr .9fr .65fr .72fr 1.05fr 1.85fr; align-items: start; gap: 16px; }
  .brand-col { padding-right: 14px; }
  .footer-logo { display: inline-block; color: #09152e; font-size: 1.65rem; font-weight: 850; letter-spacing: -.055em; line-height: 1; }
  .footer-logo::first-letter { color: var(--orange); }
  .footer-tagline { display: block; margin-top: 7px; color: var(--navy); font-size: .6rem; font-weight: 800; }
  .brand-col p { max-width: 300px; margin-top: 18px; color: #526476; font-size: .93rem; line-height: 1.62; }
  .socials { display: flex; gap: 8px; margin-top: 22px; }
  .socials a { width: 31px; height: 31px; display: grid; place-items: center; border: 1px solid #d4dee7; border-radius: 8px; color: var(--navy); background: white; transition: color .2s ease-out, border-color .2s ease-out, transform .2s ease-out; }
  .socials span { font-size: .7rem; font-weight: 850; line-height: 1; }
  .socials a:hover { transform: translateY(-2px); border-color: var(--blue); color: var(--blue); }
  .footer-col { display: flex; flex-direction: column; align-items: stretch; padding-top: 2px; }
  .footer h3 { min-height: 20px; margin: 0 0 17px; color: #122038; font-size: .84rem; font-weight: 850; line-height: 1.25; letter-spacing: .055em; text-transform: uppercase; }
  .footer-col > a { display: block; margin: 0 0 10px; color: #495c6f; font-size: .9rem; line-height: 1.4; transition: color .2s ease-out; }
  .footer-col > a:hover { color: var(--blue); }
  .contact-col > a { display: grid; grid-template-columns: 17px minmax(0,1fr); align-items: center; gap: 8px; white-space: normal; }
  .contact-col svg { flex: 0 0 auto; color: var(--navy); }
  .world-map { position: relative; min-height: 190px; display: flex; align-items: end; justify-content: center; padding: 0 12px 14px; border: 1px solid #dfe7f0; border-radius: 18px; background: #eef3fb; }
  .world-map span { position: relative; z-index: 2; color: #52687b; font-size: .68rem; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; }
  .map-svg { position: absolute; width: calc(100% - 24px); max-width: 420px; height: auto; left: 50%; top: 14px; transform: translateX(-50%); }
  .map-points circle { animation: pulse 2.4s ease-in-out infinite; }
  .map-points circle:nth-child(2) { animation-delay: .4s; }
  .map-points circle:nth-child(3) { animation-delay: .8s; }
  .map-points circle:nth-child(4) { animation-delay: 1.2s; }
  .map-points circle:nth-child(5) { animation-delay: 1.6s; }
  .map-points circle:nth-child(6) { animation-delay: 2s; }
  @keyframes pulse { 0%,100% { opacity: .5; r: 4; } 50% { opacity: 1; r: 6; } }
  .footer-bottom { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 25px; margin-top: 46px; padding-top: 20px; border-top: 1px solid #d5dfe8; color: #687a8a; font-size: .72rem; }
  .footer-bottom div { display: flex; gap: 30px; }
  .footer-bottom a:hover { color: var(--blue); }
  @media (max-width: 1120px) {
    .footer-main { grid-template-columns: 1.35fr repeat(3, 1fr); gap: 30px 24px; }
    .contact-col { grid-column: 2 / 3; }
    .world-map { grid-column: 3 / 5; }
  }
  @media (max-width: 760px) {
    .footer-main { grid-template-columns: repeat(2, 1fr); }
    .brand-col { grid-column: 1 / -1; }
    .contact-col, .world-map { grid-column: auto; }
    .world-map { min-height: 160px; }
  }
  @media (max-width: 520px) {
    .footer { padding-top: 56px; }
    .footer-main { grid-template-columns: 1fr 1fr; gap: 34px 22px; }
    .contact-col, .world-map { grid-column: 1 / -1; }
    .footer-bottom { align-items: start; flex-direction: column; }
    .footer-bottom div { flex-wrap: wrap; gap: 13px 22px; }
  }
</style>
