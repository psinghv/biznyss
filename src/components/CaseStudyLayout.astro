---
import BaseLayout from '../layouts/BaseLayout.astro';

export interface FaqItem { question: string; answer: string; }
export interface Phase { label: string; description: string; }
export interface Metric { value: string; label: string; icon: string; }

export interface CaseStudyData {
  slug: string;
  title: string;
  subtitle: string;
  metaDescription: string;
  category: string;
  industry: string;
  accent: string;
  heroIntro: string;
  executiveSummary: string[];
  businessBackground: string[];
  challenges: { title: string; description: string }[];
  objectives: string;
  discovery: string[];
  strategy: string[];
  phases: Phase[];
  implChallenges: string[];
  results: string[];
  keyLearnings: string[];
  faqs: FaqItem[];
  finalConclusion: string;
  callToAction: string;
  author: { name: string; role: string; bio: string };
  metrics: Metric[];
  timeline: string;
  datePublished: string;
  dateModified: string;
}

interface Props { data: CaseStudyData; }
const { data } = Astro.props;

const accentColors: Record<string, { bg: string; text: string; border: string; gradient: string; soft: string; glow: string }> = {
  blue: { bg: '#0a5df0', text: '#0a5df0', border: '#0a5df0', gradient: 'linear-gradient(135deg, #0a5df0, #00b8d9)', soft: 'rgba(10,93,240,.08)', glow: 'rgba(10,93,240,.28)' },
  orange: { bg: '#ef4936', text: '#ef4936', border: '#ef4936', gradient: 'linear-gradient(135deg, #ef4936, #f6a23a)', soft: 'rgba(239,73,54,.08)', glow: 'rgba(239,73,54,.28)' },
  navy: { bg: '#124f6d', text: '#124f6d', border: '#124f6d', gradient: 'linear-gradient(135deg, #124f6d, #2a7fa8)', soft: 'rgba(18,79,109,.08)', glow: 'rgba(18,79,109,.28)' },
  teal: { bg: '#0d9488', text: '#0d9488', border: '#0d9488', gradient: 'linear-gradient(135deg, #0d9488, #2dd4bf)', soft: 'rgba(13,148,136,.08)', glow: 'rgba(13,148,136,.28)' },
};
const c = accentColors[data.accent] ?? accentColors.blue;

const metricPalettes = [
  { bg: 'linear-gradient(145deg, #0a5df0, #00b8d9)', color: '#0a5df0', glow: 'rgba(10,93,240,.35)' },
  { bg: 'linear-gradient(145deg, #ef4936, #f6a23a)', color: '#ef4936', glow: 'rgba(239,73,54,.35)' },
  { bg: 'linear-gradient(145deg, #16b364, #65d6a0)', color: '#16b364', glow: 'rgba(22,179,100,.35)' },
  { bg: 'linear-gradient(145deg, #0d9488, #2dd4bf)', color: '#0d9488', glow: 'rgba(13,148,136,.35)' },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://biznyss.com/' },
    { '@type': 'ListItem', position: 2, name: 'Case Studies', item: 'https://biznyss.com/case-studies' },
    { '@type': 'ListItem', position: 3, name: data.title, item: `https://biznyss.com/case-studies/${data.slug}` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: data.faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.metaDescription,
  datePublished: data.datePublished,
  dateModified: data.dateModified,
  author: { '@type': 'Person', name: data.author.name, jobTitle: data.author.role },
  publisher: {
    '@type': 'Organization',
    name: 'Biznyss Labs',
    sameAs: ['https://biznyss.com', 'https://www.linkedin.com/company/biznyss'],
  },
};

const combinedSchema = {
  '@context': 'https://schema.org',
  '@graph': [articleSchema, breadcrumbSchema, faqSchema],
};

const sections = [
  { id: 'summary', label: 'Summary' },
  { id: 'background', label: 'Background' },
  { id: 'challenges', label: 'Challenges' },
  { id: 'strategy', label: 'Strategy' },
  { id: 'implementation', label: 'Implementation' },
  { id: 'results', label: 'Results' },
  { id: 'learnings', label: 'Learnings' },
  { id: 'faq', label: 'FAQ' },
];
---

<BaseLayout title={data.title} description={data.metaDescription} schema={combinedSchema}>
  <article class="cs-page" style={`--accent: ${c.bg}; --accent-text: ${c.text}; --accent-gradient: ${c.gradient}; --accent-soft: ${c.soft}; --accent-glow: ${c.glow};`}>
    <!-- Breadcrumb -->
    <nav class="cs-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/case-studies">Case Studies</a>
      <span class="sep">/</span>
      <span class="current">{data.title}</span>
    </nav>

    <!-- Hero -->
    <header class="cs-hero">
      <div class="cs-hero-glow" aria-hidden="true"></div>
      <div class="cs-hero-inner">
        <div class="cs-hero-tags">
          <span class="tag tag-category">{data.category}</span>
          <span class="tag tag-industry">{data.industry}</span>
        </div>
        <h1>{data.title}</h1>
        <p class="cs-hero-subtitle">{data.subtitle}</p>
        <p class="cs-hero-intro">{data.heroIntro}</p>
        <div class="cs-hero-meta">
          <span class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            {data.timeline}
          </span>
          <span class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
            {data.author.name}
          </span>
        </div>
        <div class="cs-hero-stats">
          {data.metrics.map((m, i) => (
            <div class="hero-stat">
              <span class="hero-stat-value">{m.value}</span>
              <span class="hero-stat-label">{m.label}</span>
            </div>
          ))}
        </div>
      </div>
    </header>

    <!-- Metrics Infographic -->
    <section class="cs-metrics" aria-label="Key results">
      <div class="cs-metrics-grid">
        {data.metrics.map((m, i) => {
          const p = metricPalettes[i % metricPalettes.length];
          return (
            <div class="metric-card" style={`--m-bg: ${p.bg}; --m-color: ${p.color}; --m-glow: ${p.glow}; animation-delay: ${i * 0.1}s`}>
              <div class="metric-icon" set:html={m.icon} />
              <div class="metric-value">{m.value}</div>
              <div class="metric-label">{m.label}</div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Section Nav -->
    <nav class="cs-section-nav" id="cs-nav">
      <div class="cs-nav-inner">
        {sections.map(s => (
          <a href={`#${s.id}`} class="cs-nav-link" data-target={s.id}>{s.label}</a>
        ))}
      </div>
    </nav>

    <div class="cs-content">
      <!-- Executive Summary -->
      <section id="summary" class="cs-section">
        <h2>Executive Summary</h2>
        {data.executiveSummary.map(p => <p>{p}</p>)}
      </section>

      <!-- Business Background -->
      <section id="background" class="cs-section">
        <h2>Business Background</h2>
        {data.businessBackground.map(p => <p>{p}</p>)}
      </section>

      <!-- Challenges -->
      <section id="challenges" class="cs-section">
        <h2>Challenges</h2>
        <div class="cs-challenge-grid">
          {data.challenges.map((ch, i) => (
            <div class="challenge-card">
              <div class="challenge-number">{String(i + 1).padStart(2, '0')}</div>
              <h3>{ch.title}</h3>
              <p>{ch.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Objectives -->
      <section class="cs-section cs-objectives">
        <h2>Objectives</h2>
        <div class="objectives-box">
          <p>{data.objectives}</p>
        </div>
      </section>

      <!-- Discovery & Research -->
      <section class="cs-section">
        <h2>Discovery &amp; Research</h2>
        {data.discovery.map(p => <p>{p}</p>)}
      </section>

      <!-- Strategy -->
      <section id="strategy" class="cs-section">
        <h2>Strategy</h2>
        {data.strategy.map(p => <p>{p}</p>)}
      </section>

      <!-- Implementation -->
      <section id="implementation" class="cs-section">
        <h2>Implementation</h2>
        <div class="cs-timeline">
          {data.phases.map((phase, i) => (
            <div class="timeline-item" style={`--i: ${i}`}>
              <div class="timeline-marker">
                <span class="timeline-num">{i + 1}</span>
              </div>
              <div class="timeline-content">
                <h3>{phase.label}</h3>
                <p>{phase.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Challenges During Implementation -->
      <section class="cs-section">
        <h2>Challenges During Implementation</h2>
        <div class="cs-impl-challenges">
          {data.implChallenges.map((p, i) => (
            <div class="impl-challenge-item">
              <div class="impl-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg>
              </div>
              <p>{p}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Results -->
      <section id="results" class="cs-section cs-results-section">
        <h2>Results</h2>
        <div class="cs-results-box">
          {data.results.map(p => <p>{p}</p>)}
        </div>
      </section>

      <!-- Key Learnings -->
      <section id="learnings" class="cs-section">
        <h2>Key Learnings</h2>
        <div class="cs-learnings">
          {data.keyLearnings.map((p, i) => (
            <div class="learning-item">
              <div class="learning-num">{i + 1}</div>
              <p>{p}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Final Conclusion -->
      <section class="cs-section cs-conclusion">
        <h2>Final Conclusion</h2>
        <blockquote>{data.finalConclusion}</blockquote>
      </section>

      <!-- FAQ -->
      <section id="faq" class="cs-section cs-faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="cs-faq-list">
          {data.faqs.map(faq => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <div class="faq-answer"><p>{faq.answer}</p></div>
            </details>
          ))}
        </div>
      </section>

      <!-- Author -->
      <section class="cs-author">
        <div class="author-card">
          <div class="author-avatar">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
          </div>
          <div class="author-info">
            <h3>{data.author.name}</h3>
            <p class="author-role">{data.author.role}</p>
            <p class="author-bio">{data.author.bio}</p>
          </div>
        </div>
      </section>
    </div>

    <!-- CTA -->
    <section class="cs-cta">
      <div class="cs-cta-inner">
        <h2>Ready to explore what this looks like for you?</h2>
        <p>{data.callToAction}</p>
        <div class="cs-cta-options">
          <a href="/contact" class="cs-cta-option primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            Book Strategy Call
          </a>
          <a href="https://wa.me/919999999999" class="cs-cta-option">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            Chat on WhatsApp
          </a>
          <a href="/case-studies" class="cs-cta-option">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            Explore More Case Studies
          </a>
          <a href="/capabilities" class="cs-cta-option">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20M2 12h20"/></svg>
            View Capabilities
          </a>
        </div>
      </div>
    </section>

    <!-- Floating scroll CTA -->
    <aside class="cs-float-cta" id="cs-float-cta" aria-hidden="true">
      <span class="cs-float-text">Want results like these?</span>
      <a href="/contact" class="cs-float-btn">Book Strategy Call</a>
    </aside>
  </article>
</BaseLayout>

<style>
  .cs-page { --max: 860px; font-family: 'Plus Jakarta Sans', sans-serif; color: #1a1a2e; }

  /* Breadcrumb */
  .cs-breadcrumb { max-width: var(--max); margin: 0 auto; padding: 24px 24px 0; font-size: 13px; color: #64748b; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .cs-breadcrumb a { color: var(--accent-text); text-decoration: none; font-weight: 500; transition: opacity .2s; }
  .cs-breadcrumb a:hover { opacity: .7; }
  .cs-breadcrumb .sep { color: #cbd5e1; }
  .cs-breadcrumb .current { color: #475569; font-weight: 500; }

  /* Hero — distinctive dark panel */
  .cs-hero { position: relative; overflow: hidden; padding: 56px 24px 64px; border-radius: 0 0 28px 28px; color: #fff; background: radial-gradient(120% 100% at 0% 0%, #163b5c 0%, #0a1a2e 60%, #060f1a 100%); box-shadow: 0 24px 60px rgba(6,15,26,.35); }
  .cs-hero-glow { position: absolute; width: 520px; height: 520px; right: -180px; top: -220px; border-radius: 50%; background: radial-gradient(circle, var(--accent-glow), transparent 67%); pointer-events: none; }
  .cs-hero-inner { position: relative; max-width: var(--max); margin: 0 auto; }
  .cs-hero-tags { display: flex; gap: 10px; margin-bottom: 20px; }
  .tag { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; }
  .tag-category { background: var(--accent); color: #fff; }
  .tag-industry { background: rgba(255,255,255,.12); color: #cfe0ee; border: 1px solid rgba(255,255,255,.18); }
  .cs-hero h1 { font-size: clamp(28px, 5vw, 44px); font-weight: 800; line-height: 1.15; letter-spacing: -.02em; margin: 0 0 16px; color: #fff; }
  .cs-hero-subtitle { font-size: 18px; color: #8db8ff; font-weight: 600; margin: 0 0 20px; line-height: 1.4; }
  .cs-hero-intro { font-size: 16px; line-height: 1.7; color: #aab9c6; margin: 0 0 24px; }
  .cs-hero-meta { display: flex; gap: 24px; flex-wrap: wrap; font-size: 14px; color: #9db1c4; padding-bottom: 28px; border-bottom: 1px solid rgba(255,255,255,.1); margin-bottom: 28px; }
  .meta-item { display: flex; align-items: center; gap: 6px; }
  .cs-hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .hero-stat { display: flex; flex-direction: column; gap: 4px; }
  .hero-stat-value { font-size: clamp(18px, 2.4vw, 24px); font-weight: 800; color: #fff; letter-spacing: -.02em; line-height: 1.1; }
  .hero-stat-label { font-size: 12px; color: #9db1c4; line-height: 1.35; }

  /* Metrics — 3D modern infographic, distinct colors */
  .cs-metrics { padding: 48px 24px 8px; }
  .cs-metrics-grid { max-width: var(--max); margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 18px; }
  .metric-card { position: relative; background: #fff; border: 1px solid #e2e8f0; border-radius: 18px; padding: 28px 20px; text-align: center; opacity: 0; animation: fadeUp .5s ease forwards; transform: perspective(800px) rotateX(0deg); transition: transform .35s cubic-bezier(.2,.7,.3,1), box-shadow .35s ease, border-color .35s ease; box-shadow: 0 8px 20px rgba(15,23,42,.06), inset 0 1px 0 rgba(255,255,255,.6); }
  .metric-card::before { content: ''; position: absolute; inset: 0; border-radius: 18px; padding: 1px; background: var(--m-bg); -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor; mask-composite: exclude; opacity: .35; pointer-events: none; }
  .metric-card::after { content: ''; position: absolute; left: 24px; right: 24px; top: 0; height: 3px; border-radius: 0 0 6px 6px; background: var(--m-bg); box-shadow: 0 0 18px var(--m-glow); }
  .metric-card:hover { transform: translateY(-6px) perspective(800px) rotateX(4deg); box-shadow: 0 22px 44px var(--m-glow), inset 0 1px 0 rgba(255,255,255,.6); border-color: transparent; }
  .metric-icon { width: 52px; height: 52px; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; border-radius: 14px; color: #fff; background: var(--m-bg); box-shadow: 0 8px 18px var(--m-glow), inset 0 1px 0 rgba(255,255,255,.35); transform: translateZ(20px); }
  .metric-icon :global(svg) { width: 24px; height: 24px; }
  .metric-value { font-size: 26px; font-weight: 800; color: var(--m-color); letter-spacing: -.02em; line-height: 1.1; }
  .metric-label { font-size: 13px; color: #64748b; margin-top: 6px; line-height: 1.4; }

  /* Section Nav */
  .cs-section-nav { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,.85); -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px); border-bottom: 1px solid #e2e8f0; margin-top: 48px; }
  .cs-nav-inner { max-width: var(--max); margin: 0 auto; padding: 0 24px; display: flex; gap: 4px; overflow-x: auto; scrollbar-width: none; }
  .cs-nav-inner::-webkit-scrollbar { display: none; }
  .cs-nav-link { padding: 14px 16px; font-size: 13px; font-weight: 600; color: #64748b; text-decoration: none; white-space: nowrap; border-bottom: 2px solid transparent; transition: color .2s, border-color .2s; }
  .cs-nav-link:hover { color: var(--accent-text); }
  .cs-nav-link.active { color: var(--accent-text); border-color: var(--accent); }

  /* Content */
  .cs-content { max-width: var(--max); margin: 0 auto; padding: 48px 24px; }
  .cs-section { margin-bottom: 56px; scroll-margin-top: 56px; }
  .cs-section h2 { font-size: 26px; font-weight: 700; letter-spacing: -.01em; margin: 0 0 20px; padding-bottom: 12px; border-bottom: 2px solid var(--accent-soft); position: relative; }
  .cs-section h2::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 48px; height: 2px; background: var(--accent); }
  .cs-section h3 { font-size: 18px; font-weight: 700; margin: 0 0 10px; }
  .cs-section p { font-size: 16px; line-height: 1.75; color: #334155; margin: 0 0 16px; }

  /* Challenge cards */
  .cs-challenge-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 16px; }
  .challenge-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 14px; padding: 24px; transition: border-color .2s, transform .2s; }
  .challenge-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .challenge-number { font-size: 13px; font-weight: 800; color: var(--accent-text); margin-bottom: 8px; letter-spacing: .05em; }
  .challenge-card h3 { font-size: 16px; margin: 0 0 8px; }
  .challenge-card p { font-size: 14px; line-height: 1.6; color: #64748b; margin: 0; }

  /* Objectives */
  .cs-objectives .objectives-box { background: var(--accent-soft); border-left: 4px solid var(--accent); border-radius: 0 12px 12px 0; padding: 24px 28px; }
  .cs-objectives .objectives-box p { margin: 0; font-size: 16px; line-height: 1.75; color: #1e293b; }

  /* Timeline */
  .cs-timeline { position: relative; padding-left: 0; }
  .timeline-item { display: flex; gap: 20px; padding-bottom: 32px; position: relative; }
  .timeline-item:not(:last-child)::before { content: ''; position: absolute; left: 23px; top: 48px; bottom: 0; width: 2px; background: var(--accent-soft); }
  .timeline-marker { flex-shrink: 0; width: 48px; height: 48px; border-radius: 50%; background: var(--accent-gradient); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(0,0,0,.12); }
  .timeline-num { color: #fff; font-weight: 800; font-size: 18px; }
  .timeline-content { flex: 1; padding-top: 4px; }
  .timeline-content h3 { font-size: 17px; margin: 0 0 8px; color: var(--accent-text); }
  .timeline-content p { font-size: 15px; line-height: 1.7; color: #475569; margin: 0; }

  /* Impl challenges */
  .cs-impl-challenges { display: flex; flex-direction: column; gap: 16px; }
  .impl-challenge-item { display: flex; gap: 14px; background: #fff7ed; border: 1px solid #fed7aa; border-radius: 12px; padding: 18px 20px; }
  .impl-icon { flex-shrink: 0; color: #ea580c; padding-top: 2px; }
  .impl-challenge-item p { margin: 0; font-size: 15px; line-height: 1.65; color: #475569; }

  /* Results */
  .cs-results-box { background: linear-gradient(135deg, var(--accent-soft), rgba(255,255,255,.5)); border: 1px solid var(--accent-soft); border-radius: 16px; padding: 28px 32px; }
  .cs-results-box p { margin: 0 0 16px; font-size: 16px; line-height: 1.75; }
  .cs-results-box p:last-child { margin: 0; }

  /* Learnings */
  .cs-learnings { display: flex; flex-direction: column; gap: 20px; }
  .learning-item { display: flex; gap: 16px; align-items: flex-start; }
  .learning-num { flex-shrink: 0; width: 36px; height: 36px; border-radius: 10px; background: var(--accent-gradient); color: #fff; font-weight: 800; font-size: 15px; display: flex; align-items: center; justify-content: center; }
  .learning-item p { margin: 0; font-size: 15px; line-height: 1.7; color: #334155; padding-top: 6px; }

  /* Conclusion */
  .cs-conclusion blockquote { margin: 0; padding: 28px 32px; background: #f8fafc; border-left: 4px solid var(--accent); border-radius: 0 12px 12px 0; font-size: 17px; line-height: 1.7; font-style: italic; color: #1e293b; }

  /* FAQ */
  .cs-faq-list { display: flex; flex-direction: column; gap: 10px; }
  .faq-item { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; transition: border-color .2s, box-shadow .2s; }
  .faq-item[open] { border-color: var(--accent); box-shadow: 0 4px 16px rgba(0,0,0,.06); }
  .faq-item summary { padding: 18px 24px; font-size: 15px; font-weight: 600; color: #1e293b; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; transition: background .2s; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 22px; color: var(--accent-text); font-weight: 300; transition: transform .2s; }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item summary:hover { background: var(--accent-soft); }
  .faq-answer { padding: 0 24px 18px; }
  .faq-answer p { margin: 0; font-size: 15px; line-height: 1.7; color: #475569; }

  /* Author */
  .cs-author { margin-top: 56px; padding-top: 40px; border-top: 1px solid #e2e8f0; }
  .author-card { display: flex; gap: 20px; align-items: flex-start; }
  .author-avatar { flex-shrink: 0; width: 72px; height: 72px; border-radius: 50%; background: var(--accent-soft); color: var(--accent-text); display: flex; align-items: center; justify-content: center; }
  .author-info h3 { font-size: 17px; margin: 0 0 4px; }
  .author-role { font-size: 14px; color: var(--accent-text); font-weight: 600; margin: 0 0 8px; }
  .author-bio { font-size: 14px; line-height: 1.6; color: #64748b; margin: 0; }

  /* CTA — multiple options */
  .cs-cta { background: var(--accent-gradient); padding: 64px 24px; margin-top: 0; }
  .cs-cta-inner { max-width: var(--max); margin: 0 auto; text-align: center; }
  .cs-cta h2 { color: #fff; font-size: 28px; font-weight: 800; margin: 0 0 16px; border: none; }
  .cs-cta h2::after { display: none; }
  .cs-cta p { color: rgba(255,255,255,.9); font-size: 16px; line-height: 1.6; margin: 0 0 28px; max-width: 600px; margin-left: auto; margin-right: auto; }
  .cs-cta-options { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .cs-cta-option { display: inline-flex; align-items: center; gap: 8px; padding: 13px 24px; background: rgba(255,255,255,.14); color: #fff; border: 1px solid rgba(255,255,255,.28); border-radius: 50px; font-size: 14px; font-weight: 700; text-decoration: none; transition: transform .2s, background .2s, box-shadow .2s; }
  .cs-cta-option:hover { transform: translateY(-2px); background: rgba(255,255,255,.24); box-shadow: 0 10px 24px rgba(0,0,0,.18); }
  .cs-cta-option.primary { background: #fff; color: var(--accent-text); border-color: #fff; box-shadow: 0 8px 20px rgba(0,0,0,.18); }
  .cs-cta-option.primary:hover { box-shadow: 0 12px 28px rgba(0,0,0,.26); }

  /* Floating scroll CTA */
  .cs-float-cta { position: fixed; right: 22px; bottom: 22px; z-index: 60; display: flex; align-items: center; gap: 12px; padding: 10px 12px 10px 18px; background: #fff; border: 1px solid #e2e8f0; border-radius: 50px; box-shadow: 0 14px 36px rgba(15,23,42,.16); opacity: 0; transform: translateY(20px); pointer-events: none; transition: opacity .35s ease, transform .35s ease; }
  .cs-float-cta.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .cs-float-text { font-size: 13px; font-weight: 600; color: #475569; }
  .cs-float-btn { display: inline-flex; align-items: center; padding: 9px 18px; border-radius: 50px; background: var(--accent-gradient); color: #fff; font-size: 13px; font-weight: 700; text-decoration: none; box-shadow: 0 6px 16px var(--accent-glow); transition: transform .2s; }
  .cs-float-btn:hover { transform: translateY(-2px); }
  @media (max-width: 640px) { .cs-float-cta { right: 12px; bottom: 12px; padding: 8px 10px 8px 14px; } .cs-float-text { display: none; } }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  .cs-section { opacity: 0; transform: translateY(24px); transition: opacity .5s ease, transform .5s ease; }
  .cs-section.revealed { opacity: 1; transform: translateY(0); }

  @media (max-width: 640px) {
    .cs-challenge-grid { grid-template-columns: 1fr; }
    .cs-hero-meta { gap: 16px; }
    .author-card { flex-direction: column; }
    .cs-hero-stats { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
</style>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
  document.querySelectorAll('.cs-section').forEach(s => observer.observe(s));

  // Active section nav
  const navLinks = document.querySelectorAll('.cs-nav-link');
  const sections = document.querySelectorAll('.cs-section[id]');
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          link.classList.toggle('active', link.dataset.target === id);
        });
      }
    });
  }, { threshold: 0.3, rootMargin: '-56px 0px -60% 0px' });
  sections.forEach(s => navObserver.observe(s));

  // Floating scroll CTA — appears after hero, hides near footer CTA
  const floatCta = document.getElementById('cs-float-cta');
  const hero = document.querySelector('.cs-hero');
  const footerCta = document.querySelector('.cs-cta');
  if (floatCta && hero) {
    const showObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (!e.isIntersecting) floatCta.classList.add('visible'); });
    }, { threshold: 0 });
    showObs.observe(hero);
    if (footerCta) {
      const hideObs = new IntersectionObserver((entries) => {
        entries.forEach(e => { floatCta.classList.toggle('visible', !e.isIntersecting); });
      }, { threshold: 0.2 });
      hideObs.observe(footerCta);
    }
  }
</script>
