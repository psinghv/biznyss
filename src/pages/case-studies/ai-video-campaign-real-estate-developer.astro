    { value: '~2x', label: 'Lead volume from video-driven channels', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 6l-9 9-3-3-9 9"/><path d="M17 6h6v6"/></svg>' },
    { value: '< 2 weeks', label: 'From launch-ready to full video library (was 6+)', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>' },
  ],
