---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="The page you requested could not be found.">
  <section class="missing"><div class="container"><span class="number">404</span><h1>This page has moved beyond the map.</h1><p class="lead">Return to the Biznyss ecosystem and keep exploring.</p><a class="btn btn-primary" href="/">Back to home</a></div></section>
</BaseLayout>
<style>.missing{min-height:78vh;display:grid;place-items:center;padding:150px 0 80px;text-align:center}.missing h1{max-width:800px;margin:20px auto}.missing .lead{margin-bottom:30px}</style>
