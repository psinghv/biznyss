---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTA from '../../components/CTA.astro';
const posts = (await getCollection('insights')).sort((a,b)=>b.data.published.valueOf()-a.data.published.valueOf());
const categories = ['AI','Marketing','Growth','Software','Automation','Case Studies'];
---
<BaseLayout title="Insights" description="Executive insights on AI, growth marketing, software, automation, and business transformation from Biznyss.">
  <PageHero eyebrow="Ideas for what comes next" title="Clear thinking for leaders building through change." text="Practical perspectives on AI, growth, software, automation, and the connected systems behind business performance." />
  <section class="section"><div class="container">
    <div class="pill-row categories">{categories.map((cat)=><span class="pill">{cat}</span>)}</div>
    <div class="insights-grid">{posts.map((post,i)=><a class:list={['insight-card',i===0?'featured':'']} href={`/insights/${post.id}`}><div class="insight-art"><span>{post.data.category}</span><b>{String(i+1).padStart(2,'0')}</b></div><div class="insight-content"><small>{post.data.published.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})} · {post.data.readTime}</small><h2>{post.data.title}</h2><p>{post.data.description}</p><strong class="text-link">Read insight</strong></div></a>)}</div>
  </div></section>
  <CTA title="Bring sharper thinking to your next growth decision." />
</BaseLayout>
<style>
  .categories { margin-bottom:40px }
  .insights-grid { display:grid;grid-template-columns:repeat(2,1fr);gap:25px }
  .insight-card { overflow:hidden;border:1px solid var(--border);border-radius:20px;background:white;transition:transform .3s ease-out,box-shadow .3s ease-out }
  .insight-card:hover { transform:translateY(-5px);box-shadow:var(--shadow) }
  .insight-card.featured { grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr }
  .insight-art { min-height:260px;display:flex;justify-content:space-between;padding:25px;color:white;background:linear-gradient(145deg,var(--navy),var(--blue)) }
  .insight-art span { align-self:flex-start;padding:6px 10px;border:1px solid rgba(255,255,255,.25);border-radius:999px;font-size:.7rem }
  .insight-art b { align-self:end;color:rgba(255,255,255,.2);font-size:5rem }
  .insight-content { padding:32px }
  .insight-content small { color:var(--muted);font-size:.73rem }
  .insight-content h2 { margin:18px 0 14px;font-size:clamp(1.7rem,3vw,2.7rem) }
  .insight-content p { margin-bottom:24px;color:var(--muted) }
  @media(max-width:750px){.insights-grid{grid-template-columns:1fr}.insight-card.featured{grid-column:auto;display:block}}
</style>
