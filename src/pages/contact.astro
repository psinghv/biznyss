---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import { Mail, Phone, MessageCircle, CalendarDays, MapPin, Clock, ArrowRight } from 'lucide-react';

const contactCards = [
  { icon: Mail, tone: 'blue', label: 'Email', value: 'hello@biznyss.com', href: 'mailto:hello@biznyss.com' },
  { icon: Phone, tone: 'green', label: 'Phone', value: '+91 98765 43210', href: 'tel:+919876543210' },
  { icon: MessageCircle, tone: 'orange', label: 'WhatsApp', value: 'Chat with us', href: 'https://wa.me/919876543210' },
  { icon: CalendarDays, tone: 'purple', label: 'Strategy Call', value: 'Book a session', href: '#contact-form' },
];

const responseSteps = [
  { n: '01', title: 'You reach out', text: 'Send a brief, a challenge, or a half-formed idea. No pressure, no jargon.' },
  { n: '02', title: 'We respond in 24h', text: 'A senior team member replies — not a bot, not an SDR, not a form.' },
  { n: '03', title: 'Discovery call', text: 'A 30-minute conversation to understand your goals and fit.' },
  { n: '04', title: 'Scoped proposal', text: 'A clear plan with outcomes, timeline, and investment — usually within a week.' },
];
---

<BaseLayout title="Contact Biznyss | Start a Conversation" description="Reach Biznyss by email, phone, WhatsApp, or book a strategy call. A senior team member responds within 24 hours.">
  <PageHero
    eyebrow="Contact"
    title="Let's talk about what's next."
    text="Bring us the ambition, the bottleneck, or the half-formed idea. A senior team member responds within 24 hours — no funnels, no scripts."
    variant="dark"
    visual="minimal"
  />

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-cards">
        {contactCards.map(({ icon: Icon, tone, label, value, href }) => (
          <a class={`contact-card tone-${tone}`} href={href}>
            <span class="icon-box"><Icon size={22} strokeWidth={1.8} /></span>
            <div>
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
            <ArrowRight size={18} class="card-arrow" />
          </a>
        ))}
      </div>

      <div class="contact-form-wrap">
        <div class="form-header">
          <span class="eyebrow orange">Project brief</span>
          <h2>Tell us about your goals.</h2>
          <p class="lead">The more context you share, the faster we can give you a useful response.</p>
        </div>
        <form id="contact-form" class="contact-form">
          <div class="form-row">
            <label>
              <span>Full name</span>
              <input type="text" name="name" placeholder="Jane Doe" required />
            </label>
            <label>
              <span>Work email</span>
              <input type="email" name="email" placeholder="jane@company.com" required />
            </label>
          </div>
          <div class="form-row">
            <label>
              <span>Company</span>
              <input type="text" name="company" placeholder="Company name" />
            </label>
            <label>
              <span>What do you need?</span>
              <select name="topic" required>
                <option value="">Select a capability…</option>
                <option>AI Creative Studio</option>
                <option>Growth Marketing</option>
                <option>Software & Products</option>
                <option>AI & Automation</option>
                <option>Something else</option>
              </select>
            </label>
          </div>
          <label>
            <span>What are you trying to achieve?</span>
            <textarea name="message" rows="5" placeholder="Share your goals, timeline, and any context that helps us respond usefully." required></textarea>
          </label>
          <button type="submit" class="btn btn-primary form-submit">
            Send brief <ArrowRight size={16} />
          </button>
          <p class="form-note">We respond within 24 hours. Your details stay private.</p>
        </form>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-head"><div>
        <span class="eyebrow green">What happens next</span>
        <h2>From message to proposal in four steps.</h2>
      </div></div>
      <div class="steps-grid">
        {responseSteps.map((s) => (
          <div class="step-card">
            <span class="step-num">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA title="Prefer to talk now? We're listening." />
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: start; }
  .contact-cards { display: grid; gap: 16px; position: sticky; top: 120px; }
  .contact-card { display: grid; grid-template-columns: 52px 1fr 20px; align-items: center; gap: 18px; padding: 22px 24px; border: 1px solid var(--border); border-radius: 16px; background: #fff; transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease; }
  .contact-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); border-color: #c4d8e8; }
  .contact-card .icon-box { margin: 0; width: 52px; height: 52px; }
  .contact-card span { display: block; color: var(--muted); font-size: .78rem; font-weight: 600; }
  .contact-card strong { display: block; margin-top: 4px; font-size: 1.05rem; }
  .card-arrow { color: var(--blue); transition: transform .2s ease; }
  .contact-card:hover .card-arrow { transform: translateX(4px); }

  .form-header { margin-bottom: 32px; }
  .form-header h2 { margin: 8px 0 14px; }
  .contact-form { display: grid; gap: 20px; padding: 40px; border: 1px solid var(--border); border-radius: 24px; background: #fff; box-shadow: var(--shadow); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .contact-form label { display: grid; gap: 8px; }
  .contact-form span { color: var(--navy); font-size: .85rem; font-weight: 700; }
  .contact-form input, .contact-form select, .contact-form textarea {
    padding: 14px 16px; border: 1px solid var(--border); border-radius: 12px; background: var(--surface); color: var(--ink); font-size: .95rem; transition: border-color .2s ease, background .2s ease;
  }
  .contact-form input:focus, .contact-form select:focus, .contact-form textarea:focus { outline: none; border-color: var(--blue); background: #fff; }
  .form-submit { width: max-content; }
  .form-note { color: var(--muted); font-size: .82rem; }

  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .step-card { padding: 30px 26px; border-radius: 18px; background: #fff; border: 1px solid var(--border); }
  .step-num { display: block; margin-bottom: 16px; color: var(--orange); font-size: 1.6rem; font-weight: 800; letter-spacing: -.03em; }
  .step-card h3 { font-size: 1.1rem; margin-bottom: 10px; }
  .step-card p { color: var(--muted); font-size: .9rem; }

  @media (max-width: 960px) {
    .contact-grid { grid-template-columns: 1fr; gap: 32px; }
    .contact-cards { position: static; grid-template-columns: 1fr 1fr; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 680px) {
    .contact-cards { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .contact-form { padding: 26px; }
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
